# ── Environment / Secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local

# ── Node dependencies ─────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Build output (rebuilt on server after pull) ───────────────────────────────
frontend/dist/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
server.log
npm-debug.log*
yarn-debug.log*

# ── PM2 ──────────────────────────────────────────────────────────────────────
.pm2/

# ── AI model caches (downloaded at runtime) ──────────────────────────────────
.model-cache/
*.traineddata
cache/
uploads/
server.err
_test_*.js

# ── Dev / test files ──────────────────────────────────────────────────────────
backend/public/tg-debug.php
backend/public/db-setup.php
db-setup.php
api-test.php
ping.php
sample-biodata.html

# ── Vercel (not used in server deploy) ────────────────────────────────────────
.vercel/

